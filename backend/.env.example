APP_NAME=GST ITC Recon Copilot API
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO
APP_DATA_DIR=backend/runtime
JOB_RUNNER_MODE=local
WORKER_AUTH_ENABLED=true
WORKER_BEARER_TOKEN=replace_with_long_random_token

MISTRAL_API_KEY=replace_with_hackathon_key
MISTRAL_BASE_URL=https://api.mistral.ai
MISTRAL_TIMEOUT_MS=120000
MISTRAL_ENABLE_DOC_AI=false
MISTRAL_ENABLE_CHAT=false
MISTRAL_MODEL_OCR=mistral-ocr-latest
MISTRAL_MODEL_EXTRACT_FAST=ministral-3b-latest
MISTRAL_MODEL_EXTRACT_DEFAULT=ministral-8b-latest
MISTRAL_MODEL_EXTRACT_FALLBACK=ministral-14b-latest
MISTRAL_MODEL_REASONING=magistral-medium-latest
MISTRAL_MODEL_REPORT_CHAT=mistral-large-latest
MISTRAL_MODEL_VOICE_STT=voxtral-mini-latest

ELEVENLABS_ENABLE_TTS=false
ELEVENLABS_API_KEY=replace_with_elevenlabs_key
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_VOICE_ID_EN=replace_with_voice_id
ELEVENLABS_VOICE_ID_HI=replace_with_voice_id
ELEVENLABS_VOICE_ID_TA=replace_with_voice_id
ELEVENLABS_ENABLE_STT=false
ELEVENLABS_STT_MODEL=scribe_v1
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_TIMEOUT_MS=45000
ELEVENLABS_MAX_CHARS=1200

GCP_PROJECT_ID=replace_with_gcp_project_id
GCP_REGION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GCS_UPLOAD_BUCKET=replace_with_bucket
GCS_EXPORT_BUCKET=replace_with_bucket

FIREBASE_PROJECT_ID=replace_with_firebase_project_id
FIRESTORE_DATABASE=(default)
FIREBASE_STORAGE_BUCKET=replace_with_bucket
FIRESTORE_JOBS_COLLECTION=jobs

CLOUD_TASKS_ENABLED=false
CLOUD_TASKS_PROJECT_ID=replace_with_gcp_project_id
CLOUD_TASKS_LOCATION=asia-south1
CLOUD_TASKS_QUEUE=gst-recon-jobs
CLOUD_TASKS_RUN_ENDPOINT=https://your-cloud-run-url/v1/jobs/{job_id}/run
CLOUD_TASKS_SERVICE_ACCOUNT_EMAIL=cloud-tasks-invoker@your-project.iam.gserviceaccount.com
CLOUD_TASKS_OIDC_AUDIENCE=https://your-cloud-run-url
